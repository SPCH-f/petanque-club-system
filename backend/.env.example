# ============================================================
# Petanque Backend — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Server
NODE_ENV=development
PORT=5000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=petanque_user
DB_PASSWORD=petanque_pass
DB_NAME=petanque_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change_this_to_a_very_long_random_secret_key_at_least_64_chars
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=change_this_refresh_secret_too_different_from_above
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Frontend URL (for CORS and OAuth redirect)
FRONTEND_URL=http://localhost:3000

# Email (Nodemailer - Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=supachok.pa.65@gmail.com
EMAIL_PASS=Spch0642

# Email sender info
EMAIL_FROM_NAME=ชมรมเปตองมหาวิทยาลัย
EMAIL_FROM_ADDR=noreply@petanque.club

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5

# Cancel policy
CANCEL_BEFORE_HOURS=2
